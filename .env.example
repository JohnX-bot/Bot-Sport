################################################################################
# CONFIGURACION DEL BOT MULTI-LIGA - BotSport
# Copia este archivo como ".env" y completa tus credenciales
################################################################################

# ════════════════════════════════════════════════════════════════════════════
# 1. MODO DE EJECUCION
# ════════════════════════════════════════════════════════════════════════════
# true  = PAPER MODE (simulado, NO ejecuta órdenes reales, SEGURO)
# false = LIVE MODE (órdenes reales en Polymarket, requiere credenciales)
PAPER_MODE=true

# ════════════════════════════════════════════════════════════════════════════
# 2. CREDENCIALES EXTERNAS
# ════════════════════════════════════════════════════════════════════════════

# Football-Data.org API Key (para datos en vivo de partidos)
# Obtener GRATIS en: https://www.football-data.org/
FOOTBALL_DATA_API_KEY=TU_CLAVE_AQUI

# Polymarket Credenciales (solo si PAPER_MODE=false)
# No requerido para PAPER_MODE
PRIVATE_KEY=
POLYMARKET_ADDRESS=

# ════════════════════════════════════════════════════════════════════════════
# 3. CONFIGURACION DE BANKROLL (Capital de Trading)
# ════════════════════════════════════════════════════════════════════════════
BANKROLL_USDC=100.0
BET_MIN_USDC=1.0
BET_MAX_USDC=15.0
KELLY_FRACTION=0.20

# ════════════════════════════════════════════════════════════════════════════
# 4. UMBRALES DE EDGE
# ════════════════════════════════════════════════════════════════════════════
MIN_EDGE_HOME=0.04
MIN_EDGE_DRAW=0.06
MIN_EDGE_AWAY=0.04

# ════════════════════════════════════════════════════════════════════════════
# 5. GESTION DE POSICIONES
# ════════════════════════════════════════════════════════════════════════════
POSITIONS_MAX=6
MATCHES_PER_WEEK=5

# ════════════════════════════════════════════════════════════════════════════
# 6. TIMING Y ACTUALIZACION
# ════════════════════════════════════════════════════════════════════════════
FIXTURES_REFRESH_HOURS=6
MARKET_WAIT_TIMEOUT=3600

# ════════════════════════════════════════════════════════════════════════════
# 7. EXIT ANTICIPADO / STOP-LOSS
# ════════════════════════════════════════════════════════════════════════════
SELL_WIN_ODDS=0.90
SELL_WIN_MIN_REM_SECS=600
STOP_LOSS_RATIO=0.0

# ════════════════════════════════════════════════════════════════════════════
# 8. LOGGING
# ════════════════════════════════════════════════════════════════════════════
RECORD_SNAPSHOTS=true
SNAPSHOT_INTERVAL_SECS=60
TRADES_FILE=logs/match_history.json
SNAPSHOTS_FILE=logs/predictions.jsonl
ML_STATE_FILE=logs/ml_state.json
POSITIONS_FILE=logs/positions.json

# ════════════════════════════════════════════════════════════════════════════
# 9. API FOOTBALL-DATA.ORG
# ════════════════════════════════════════════════════════════════════════════
FOOTBALL_DATA_CACHE_SECS=30
FOOTBALL_DATA_TIMEOUT_SECS=5
FOOTBALL_DATA_RETRIES=2
